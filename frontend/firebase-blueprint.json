{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An artisanal product made of raffia.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string", "enum": ["Chapeaux", "Sacs", "Sandales", "Accessoires"] },
        "image": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "object" },
        "paymentMethod": { "type": "string" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "isAdmin": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of products available for sale."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    }
  }
}
